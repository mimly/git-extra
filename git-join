#!/bin/bash

# shellcheck disable=SC1091,SC2034

set -o errexit
set -o errtrace
set -o nounset
set -o pipefail

. bash_template.sh
. fs4git.sh

SCRIPT_DESCRIPTION="join revisions"
SCRIPT_FULL_DESCRIPTION="-"
SCRIPT_ARGUMENTS="[OPTION]... [FILE]..."
SCRIPT_OPTIONS=(\
    "-d DATE, --date=DATE"\
    "-m MESSAGE, --message=MESSAGE"\
    "-f FROM, --from=FROM"\
    "-t TO, --to=TO"\
    "-v, --verbose"\
    "--help"\
    "--version"\
)
SCRIPT_OPTION_DESCRIPTIONS=(\
    "date format is YYYY-MM-DDThh:mm:ss"\
    ""\
    "first revision (incl.)"\
    "last revision (excl.)"\
    "explain what is being done"\
    "display this help and exit"\
    "output version information and exit"\
)
SCRIPT_EXAMPLES=(\
    "2..4  # joins 2nd and 3rd revision with 2nd revisions date and message"\
)
SCRIPT_SEE_ALSO=(\
    "git-logs(1)"\
    "git-revision(1)"\
    "git-save(1)"\
)

# # #   D E F A U L T   V A L U E S   # # #
ORIGIN_HASH=$(commitHash HEAD)
# # #   E N D   # # # # # # # # # # # # # #

# We use "$@" instead of $* to preserve argument-boundary information
# Add : to suppress getopt error messages, i.e. getopt -o ':...'
ARGS=$(getopt -o 'd:m:f:t:v' --long 'date:,message:,from:,to:,verbose,help,version,update-manual' -- "$@") || { usage ; exit 1 ; }
eval "set -- $ARGS"

while true; do
    case $1 in
        (-d|--date)
            isValidDate "$2" || { error "date format is YYYY-mm-ddTHH:MM:SS" ; usage ; exit 1 ; }
            DATE=$2 ; shift 2 ;;
        (-m|--message)
            MESSAGE=$2 ; shift 2 ;;
        (-f|--from)
            isValidCommit "$2" || { error "revision does not exist" ; usage ; exit 1 ; }
            FROM=$(commitNumber "$2") ; shift 2 ;;
        (-t|--to)
            isValidCommit "$2" || { error "revision does not exist" ; usage ; exit 1 ; }
            TO=$(commitNumber "$2") ; shift 2 ;;
        (-v|--verbose)
            VERBOSE= ; shift ;;
        (--help)
            usageFull ; exit 0 ;;
        (--version)
            about ; changelog ; exit 0 ;;
        (--update-manual) # hidden option
            updateManual ; exit 0 ;;
        (--)
            shift ; break ;;
        (*)
            usage ; exit 1 ;;
    esac
done

REMAINING_ARGS=("$@")

# # #   H E L P   F U N C T I O N S   # # #
originRevision() {
    git reflog | grep "${ORIGIN_HASH:0:6}" | head -1 | awk '{ print substr($2, 0, length($2) - 1) }'
}

originStash() {
    git stash list | grep origin_stash | awk -F: '{ print $1 }'
}

updatedOriginStash() {
    git stash list | grep updated_origin_stash | awk -F: '{ print $1 }'
}

lastNonOriginStash() {
    git stash list | grep -v origin_stash | head -1 | awk -F: '{ print $1 }'
}

numberOfStashes() {
    git stash list | wc -l
}
# # #   E N D   # # # # # # # # # # # # # #

main() {
    ERRORS=()

    local NUMBER_OF_REVISIONS
    NUMBER_OF_REVISIONS=$(numberOfCommitsBetween "$FROM" "$TO")
    if [[ $NUMBER_OF_REVISIONS -lt 1 || $NUMBER_OF_REVISIONS -gt $(( $(totalNumberOfCommits HEAD) - FROM )) ]] ; then
        error "wrong revision range" ; usage ; exit 1
    fi

    local JOINED_REVISIONS=()
    for HASH in $(git rev-list --abbrev-commit "$(commitHash "$TO")".."$(commitHash "$FROM")") ; do
        JOINED_REVISIONS+=("$(git logs --revision "$HASH")")
    done

    if [[ -z ${VERBOSE+set} ]] ; then
        exec 3>&1 4>&2 1>/dev/null 2>&1
    fi

    NUMBER_OF_STASHES_BEFORE=$(numberOfStashes)

    if [[ -n $(git status --porcelain) ]] ; then
        git stash push --all --message origin_stash
    fi

    local COMMIT_MESSAGES=()
    local COMMIT_DATES=()
    for (( i = 0; i < FROM - 1; ++i )) ; do
        COMMIT_MESSAGES[$i]=$(commitMessage HEAD)
        COMMIT_DATES[$i]=$(commitDate HEAD)
        git reset --soft HEAD~1
        git stash push --all
    done

    : "${DATE:=$(commitDate HEAD)}"
    : "${MESSAGE:=$(commitMessage HEAD)}"
    : "${FILE:=${REMAINING_ARGS[@]}}"

    git reset --soft HEAD~"$NUMBER_OF_REVISIONS"
    git revision --verbose --date "$DATE" "$MESSAGE"

    if [[ -n $(originStash) && -n ${FILE[*]} ]] ; then
        git stash apply "$(originStash)" || { ERRORS+=("file had been created at later revision") ; return 1 ; }
        git revision --verbose --amend --no-auto-indexing --date "$DATE" "$MESSAGE" "$FILE"
        git stash push --all --message updated_origin_stash
    fi

    for (( i = FROM - 2; i >= 0; --i )) ; do
        git stash pop "$(lastNonOriginStash)"
        git revision --verbose --date "${COMMIT_DATES[$i]}" "${COMMIT_MESSAGES[$i]}"
    done

    if [[ -n $(updatedOriginStash) ]] ; then
        git stash pop "$(updatedOriginStash)"
    elif [[ -n $(originStash) ]] ; then
        git stash pop "$(originStash)"
    fi

    if [[ -z ${VERBOSE+set} ]] ; then
        exec 1>&3 2>&4
    fi

    for REVISION in "${JOINED_REVISIONS[@]}" ; do
        printf "%s\n" "$REVISION"
    done
    printf "* * * REVISIONS JOINED AS FOLLOWS: * * *\n\n"
    git logs --revision "$FROM"
}

recover() {
    # Reset the index, but not the working tree (i.e., the changed files are preserved but not marked for commit)
    git reset "$(originRevision)" --
    git stash push --all

    # Remove any dangling stashes and apply (if any) unstaged changes/untracked files
    if [[ -n "$(updatedOriginStash)" ]] ; then
        git stash drop "$(updatedOriginStash)"
    fi

    if [[ -n "$(originStash)" ]] ; then
        git stash pop "$(originStash)" || ERRORS+=("no origin stash entry")
    fi

    NUMBER_OF_STASHES_AFTER=$(numberOfStashes)
    for (( i = 0; i < NUMBER_OF_STASHES_AFTER - NUMBER_OF_STASHES_BEFORE; ++i )) {
        git stash drop
    }

    if [[ -z ${VERBOSE+set} ]] ; then
        exec 1>&3 2>&4
    fi

    for ERROR_MESSAGE in "${ERRORS[@]}" ; do
        error "$ERROR_MESSAGE"
    done
    error "recovered at $ORIGIN_HASH" ; usage ; exit 1
}

trap recover SIGINT ERR && main
